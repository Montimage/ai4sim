# ==============================================
# AI4SIM Dashboard - Configuration Exemple
# COPIEZ ce fichier vers .env et modifiez les valeurs
# ==============================================

# ===========================================
# BASE DE DONNÉES
# ===========================================
MONGODB_URI=mongodb://localhost:27017/ai4sim-dashboard
# Pour MongoDB Atlas : mongodb+srv://username:password@cluster.mongodb.net/ai4sim-dashboard

# ===========================================
# SÉCURITÉ & AUTHENTIFICATION (OBLIGATOIRE)
# ===========================================
# Clé secrète JWT - GÉNÉREZ UNE CLÉ UNIQUE !
# Commande : openssl rand -base64 32
JWT_SECRET=CHANGE-THIS-SECRET-KEY-IN-PRODUCTION-MIN-32-CHARS

# Durée d'expiration des tokens
JWT_EXPIRES_IN=24h

# Rounds de hachage bcrypt (10-12 recommandé)
BCRYPT_ROUNDS=12

# ===========================================
# COMPTES ADMINISTRATEUR INITIAUX
# ===========================================
# Super administrateur (création initiale)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_EMAIL=admin@ai4sim.local

# Administrateur standard
ADMIN_PASSWORD=ChangeMe123!

# ===========================================
# SERVEUR
# ===========================================
PORT=3000
WS_PORT=9090
HOST=localhost
NODE_ENV=development

# ===========================================
# LIMITATIONS DE SÉCURITÉ
# ===========================================
# Tentatives de connexion
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=30

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Connexions WebSocket
MAX_WS_CONNECTIONS=50

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FILE=server.log

# ===========================================
# OUTILS EXTERNES - CHEMINS CONFIGURABLES
# ===========================================
# Répertoire racine des outils
TOOLS_ROOT=./tools

# MAIP Configuration
MAIP_PATH=./tools/maip
MAIP_SCRIPT=./start_maip.sh
MAIP_SERVER_SCRIPT=./start_maip_server.sh
MAIP_PORT=31057
MAIP_CLIENT_PORT=3001

# Caldera Configuration  
CALDERA_PATH=./tools/caldera
CALDERA_SCRIPT=./start_caldera.sh
CALDERA_PORT=8888

# GAN Fuzzer
GAN_FUZZER_PATH=./tools/gan-fuzzer
GAN_FUZZER_SCRIPT=./gan_fuzzer.sh

# KNX Fuzzer
KNX_FUZZER_PATH=./tools/knx-fuzzer  
KNX_FUZZER_SCRIPT=./knx_fuzzer.sh

# LLM Generator
LLM_GENERATOR_PATH=./tools/llm-generator
LLM_GENERATOR_SCRIPT=./llm_generator.sh

# ===========================================
# DÉVELOPPEMENT UNIQUEMENT
# ===========================================
# Debug mode (ne pas activer en production)
DEBUG_MODE=false
VERBOSE_LOGGING=false

# CORS Origins (séparer par virgules)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# PRODUCTION - À CONFIGURER
# ===========================================
# SSL/HTTPS
# SSL_KEY_PATH=/path/to/ssl/private.key  
# SSL_CERT_PATH=/path/to/ssl/certificate.crt

# Monitoring
# MONITORING_ENDPOINT=https://your-monitoring-service.com

# Notifications
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASS=your-app-password
