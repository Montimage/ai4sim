# ==============================================
# MMT-Pentester Dashboard - Configuration Example
# COPY this file to .env and modify the values
# ==============================================

# ===========================================
# DATABASE
# ===========================================
MONGODB_URI=mongodb://localhost:27017/mmt-pentester
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mmt-pentester

# ===========================================
# SECURITY & AUTHENTICATION (REQUIRED)
# ===========================================
# JWT secret key - GENERATE A UNIQUE KEY!
# Command: openssl rand -base64 32
JWT_SECRET=CHANGE-THIS-SECRET-KEY-IN-PRODUCTION-MIN-32-CHARS

# Registration invite code — leave unset to disable registration entirely
# Command: openssl rand -base64 12
REGISTER_INVITE_CODE=CHANGE-THIS-INVITE-CODE

# Token expiration duration
JWT_EXPIRES_IN=24h

# Bcrypt hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=12

# ===========================================
# INITIAL ADMINISTRATOR ACCOUNTS
# ===========================================
# Super administrator (initial creation)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Standard administrator
ADMIN_PASSWORD=ChangeMe123!

# ===========================================
# SERVER
# ===========================================
PORT=3000
WS_PORT=9090
HOST=localhost
NODE_ENV=development

# ===========================================
# SECURITY LIMITATIONS
# ===========================================
# Login attempts
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=30

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# WebSocket connections
MAX_WS_CONNECTIONS=50

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FILE=server.log

# ===========================================
# EXTERNAL TOOLS - CONFIGURABLE PATHS
# ===========================================
# Root directory of tools
TOOLS_ROOT=./tools

# MAIP Configuration
MAIP_PATH=./tools/maip
MAIP_SCRIPT=./start_maip.sh
MAIP_SERVER_SCRIPT=./start_maip_server.sh
MAIP_PORT=31057
MAIP_CLIENT_PORT=3001

# Caldera Configuration
CALDERA_PATH=./tools/caldera
CALDERA_SCRIPT=./start_caldera.sh
CALDERA_PORT=8888

# GAN Fuzzer
GAN_FUZZER_PATH=./tools/gan-fuzzer
GAN_FUZZER_SCRIPT=./gan_fuzzer.sh

# KNX Fuzzer
KNX_FUZZER_PATH=./tools/knx-fuzzer
KNX_FUZZER_SCRIPT=./knx_fuzzer.sh

# LLM Generator
LLM_GENERATOR_PATH=./tools/llm-generator
LLM_GENERATOR_SCRIPT=./llm_generator.sh

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Debug mode (do not enable in production)
DEBUG_MODE=false
VERBOSE_LOGGING=false

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
