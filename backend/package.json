{
  "name": "mmt-pentester-dashboard-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' nodemon --signal SIGTERM",
    "build": "tsc",
    "start": "NODE_OPTIONS='--no-deprecation' node dist/server.js",
    "init-super-admin": "NODE_OPTIONS='--no-deprecation' ts-node src/scripts/initSuperAdmin.ts",
    "reset-users": "NODE_OPTIONS='--no-deprecation' ts-node -e \"import('./src/scripts/initSuperAdmin').then(m => m.resetAllUsers())\""
  },
  "dependencies": {
    "axios": "^1.8.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "puppeteer": "^24.15.0",
    "socket.io": "^4.7.2",
    "systeminformation": "^5.25.11",
    "tcp-port-used": "^1.0.2",
    "together-ai": "^0.39.0",
    "winston": "^3.17.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^20.10.4",
    "@types/tcp-port-used": "^1.0.4",
    "@types/ws": "^8.5.10",
    "mobx-react-lite": "^4.1.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "description": "Backend API for MMT-Pentester Dashboard — Node.js + Express + MongoDB",
  "main": "index.js",
  "keywords": ["cybersecurity", "pentesting", "montimage"],
  "author": "Montimage <contact@montimage.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Montimage/ai4sim.git"
  },
  "type": "commonjs"
}
